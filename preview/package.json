{
  "name": "@fern-github-actions/preview",
  "version": "1.0.0",
  "private": true,
  "description": "GitHub Action to publish preview SDKs and post PR comments with install links and SDK diff links",
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
