    "@actions/io": "^1.1.3",
    "@fern-github-actions/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "overrides": {
    "undici": "^6.23.0"
  },
  "engines": {
    "node": ">=20"
  }
