# Dependencies
node_modules/

# pnpm
.pnpm-store/
.pnpm-debug.log

# Build outputs
# NOTE: actions/*/dist/index.js must be committed for real actions - GitHub runners execute dist/index.js directly
# Sourcemaps are NOT committed to main: they're uploaded to Sentry by the release workflow
# and only live on the dist/<action> orphan branches alongside the bundle.
# The example-action dist is excluded as it's only a template
packages/*/dist/
actions/example-action/dist/
*/dist/*.map
build/
out/
lib/

# Environment variables
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
*.swp
*.swo

# Claude Code
.claude/

# TypeScript
*.tsbuildinfo

# Coverage
coverage/
